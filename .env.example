DB_CONNECTION_STRING=Host=<host-postgres>;Port=5432;Database=<db>;Username=<user>;Password=<password>

RABBITMQ_HOST=<host-rabbitmq>
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=<user>
RABBITMQ_PASSWORD=<password>
RABBITMQ_QUEUE=cerberus.quality-gate.queue
RABBITMQ_EXCHANGE=cerberus.findings.ready
RABBITMQ_RESULTS_EXCHANGE=cerberus.gate.results

QUALITY_GATE_INTERNAL_TOKEN=<token-interno-real>
KUBERNETES_NAMESPACE=cerberus
K8S_API_URL=https://kubernetes.default.svc
K8S_SERVICE_ACCOUNT_TOKEN=<token-service-account-k8s>

EXPECTED_SCAN_RESULTS_PER_SCAN=2
PENDING_SCAN_TIMEOUT_SECONDS=30
